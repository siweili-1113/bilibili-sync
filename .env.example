# ============================================
# B站同步工具 - 配置文件
# 复制为 .env 后填入真实值
# ============================================

# B站账号 Cookie（从浏览器获取）
# 方法: 浏览器登录 bilibili.com → F12 → Console → 输入:
#   document.cookie.split(';').filter(c=>c.includes('SESSDATA'))
#   document.cookie.split(';').filter(c=>c.includes('bili_jct'))
BILIBILI_SESSDATA=
BILIBILI_CSRF=

# LLM API（OpenAI 兼容接口）
# DeepSeek: https://api.deepseek.com/v1
# OpenAI:   https://api.openai.com/v1
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-v4-flash
